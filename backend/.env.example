# ================================
# SMART TRADER APP - CONFIGURACION
# ================================

# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=smart_trader_db

# ✅ Anthropic API (Claude directo - sin Emergent)
# Obtén tu key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Modelo de Claude. Default: claude-opus-4-8 (máxima calidad).
# Alternativas más baratas/rápidas: claude-sonnet-4-6, claude-haiku-4-5
ANTHROPIC_MODEL=claude-opus-4-8

# Binance Spot
BINANCE_API_KEY=tu_binance_api_key
BINANCE_API_SECRET=tu_binance_api_secret
BINANCE_TESTNET=true

# Binance Futures (opcional)
BINANCE_FUTURES_KEY=
BINANCE_FUTURES_SECRET=

# ── Multi-exchange (opcional — deja vacío para usar solo Binance) ──
# Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
# OKX (requiere passphrase además de key/secret)
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
# Kraken — leer precios es PÚBLICO (no necesita key). Key solo para ejecutar órdenes.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Comisión del exchange (Binance maker/taker estándar = 0.001 = 0.1%)
COMMISSION_RATE=0.001

# ── Motor de auto-trading ──
# Segundos entre escaneos de mercado
ENGINE_SCAN_INTERVAL=30
# Usar IA de Claude en las decisiones (true requiere ANTHROPIC_API_KEY). Por ahora false.
ENGINE_USE_AI=false

# ── Arbitraje ──
# Registra un exchange simulado (SimEx) para demostrar el scanner de arbitraje sin
# una segunda API key. Ponlo en false cuando conectes Bybit/OKX reales.
ARBITRAGE_SIMULATE=true

# Trading Mode: signals_only | semi_auto | auto
TRADING_MODE=semi_auto
AUTO_TRADE_ENABLED=false

CORS_ORIGINS=*
